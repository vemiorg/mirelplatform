{
  "name": "mirelplatform",
  "version": "3.2.79",
  "description": "mirelplatform monorepo",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter frontend-v3 dev",
    "build": "pnpm --filter frontend-v3 build",
    "preview": "pnpm --filter frontend-v3 preview",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter e2e test",
    "test:e2e:ui": "pnpm --filter e2e test:ui",
    "test:e2e:report": "pnpm --filter e2e test:report"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@11.9.0",
  "pnpm": {
    "overrides": {
      "undici": "^8.5.0",
      "rollup": "^4.62.2",
      "flatted": "^3.4.2",
      "@isaacs/brace-expansion": "^5.0.1",
      "lodash": "^4.18.1",
      "minimatch": "^10.2.5",
      "@microsoft/api-extractor": "^7.58.9"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19",
        "eslint-plugin-react-hooks>eslint": ">=10"
      }
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "prettier": "^3.9.4"
  }
}
